# Core API
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DB_CLIENT=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wearefamily
TENANT_MODE=saas
DEFAULT_TENANT_ID=tenant-demo
AUTO_MIGRATE=true
AUTH_REQUIRED=true
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=wearefamily-api
JWT_EXPIRES_IN=12h
UPLOAD_DIR=./uploads

# Income benchmark (default: National Bureau of Statistics, China)
BENCHMARK_PROVIDER=nbs
BENCHMARK_NBS_ENDPOINT=https://data.stats.gov.cn/easyquery.htm
BENCHMARK_NBS_DB_CODE=hgnd
BENCHMARK_NBS_INDICATOR=A0A0101
BENCHMARK_SOURCE=nbs-hgnd-a0a0101
BENCHMARK_REGION=CN
BENCHMARK_CURRENCY=CNY
BENCHMARK_FETCH_INTERVAL_HOURS=168
BENCHMARK_TIMEOUT_MS=8000
BENCHMARK_DEFAULT_ANNUAL_INCOME=36000
BENCHMARK_SCHEDULER_ENABLED=true

# Optional url provider fallback
BENCHMARK_INCOME_URL=
